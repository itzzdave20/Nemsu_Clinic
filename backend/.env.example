PORT=5000
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=nemsu_clinic
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES=7d
FRONTEND_URL=http://localhost:5173

# ── Email (SMTP) ──────────────────────────────────────
# Gmail: enable 2FA → create App Password
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="NEMSU HealthHub" <your-email@gmail.com>
# Campus/dev TLS issues only:
# SMTP_REJECT_UNAUTHORIZED=false

# ── SMS (Semaphore — Philippines) ─────────────────────
# https://semaphore.co/
SEMAPHORE_API_KEY=your-semaphore-api-key
SEMAPHORE_SENDER=NEMSUC

# ── Automated Reminders ───────────────────────────────
REMINDER_CRON_ENABLED=false
REMINDER_CRON_SCHEDULE=0 8 * * *
REMINDER_DEFAULT_CHANNEL=in_app
