# Docker environment — copy to .env and customize
DB_ROOT_PASSWORD=your-secure-root-password
JWT_SECRET=your-long-random-jwt-secret-min-32-chars
FRONTEND_URL=http://localhost

# Email (Gmail App Password recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="NEMSU HealthHub" <noreply@nemsu.edu.ph>

# SMS (https://semaphore.co/)
SEMAPHORE_API_KEY=
SEMAPHORE_SENDER=NEMSUC

# Automated daily reminders at 8 AM
REMINDER_CRON_ENABLED=true
REMINDER_CRON_SCHEDULE=0 8 * * *
REMINDER_DEFAULT_CHANNEL=email
